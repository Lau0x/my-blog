{
  "kind": "collectionType",
  "collectionName": "notes",
  "info": {
    "singularName": "note",
    "pluralName": "notes",
    "displayName": "说说",
    "description": "轻量化记录（类 Twitter 动态）。支持 markdown、图片/视频、标签、时间线"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "content": {
      "type": "richtext",
      "required": true
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images", "videos"]
    },
    "tags": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    },
    "publishedDate": {
      "type": "datetime"
    }
  }
}
