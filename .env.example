# ========================================
# 域名（NPM 反代指向这个）
# ========================================
DOMAIN=blog.yourdomain.com

# ========================================
# PostgreSQL
# ========================================
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ========================================
# Strapi 密钥六件套
# 生成方法：openssl rand -base64 32
# APP_KEYS 要 4 个，用逗号分隔
# ========================================
APP_KEYS=key1,key2,key3,key4
ADMIN_JWT_SECRET=CHANGE_ME
JWT_SECRET=CHANGE_ME
API_TOKEN_SALT=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# ========================================
# 镜像源（默认拉 GHCR 上已构建好的镜像）
# ========================================
# GitHub 用户名必须小写；仓库名要和 GitHub 仓库名一致
IMAGE_REGISTRY=ghcr.io/lau0x/my-blog
IMAGE_TAG=latest

# ========================================
# 广告
# ========================================
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

# ========================================
# NPM 所在的 docker network 名
# 查法：docker network ls | grep npm
# 常见值：nginx-proxy-manager_default / npm_default
# ========================================
NPM_NETWORK=npm_default
