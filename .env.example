# ============================================
# 必填（请手动修改成你的值）
# ============================================

# 博客域名（NPM Proxy Host 指向它）
DOMAIN=<YOUR_DOMAIN>


# ============================================
# 镜像源（默认用上游作者的公开镜像，零构建直接跑）
# ============================================
# 【路径 A · 默认】用上游作者 @Lau0x 维护的公开镜像——无需 fork、无需 CI
# 【路径 B · 定制化】fork 本仓库后，改成你自己的 GHCR 路径：
#     IMAGE_REGISTRY=ghcr.io/<你的用户名>/my-blog   (全小写！)
# 详见 docs/deployment/quick-start.md
IMAGE_REGISTRY=ghcr.io/lau0x/my-blog
IMAGE_TAG=latest

# AdSense 广告客户端 ID（可选，没有就留占位）
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx


# ============================================
# 数据库配置（db 名/用户名可自定义，密码自动生成）
# ============================================
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=__AUTO_GENERATED__


# ============================================
# Strapi 密钥（全部自动生成，不要手动改）
# 运行 ./scripts/init.sh 会自动填充
# ============================================
APP_KEYS=__AUTO_GENERATED__
ADMIN_JWT_SECRET=__AUTO_GENERATED__
JWT_SECRET=__AUTO_GENERATED__
API_TOKEN_SALT=__AUTO_GENERATED__
TRANSFER_TOKEN_SALT=__AUTO_GENERATED__
ENCRYPTION_KEY=__AUTO_GENERATED__


# ============================================
# 仅"同机 NPM"部署需要（跨机部署可忽略）
# 查法：docker network ls | grep npm
# 用法：docker compose -f docker-compose.yml -f docker-compose.same-host.yml up -d
# ============================================
NPM_NETWORK=npm_default
